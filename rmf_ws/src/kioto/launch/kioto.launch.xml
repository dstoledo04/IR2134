<?xml version='1.0'?>
<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="failover_mode" default="false"/>

  <node pkg="rmf_building_map_tools" exec="building_map_server"
        args="$(find-pkg-share kioto)/maps/kioto/kioto.building.yaml">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_schedule" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_blockade" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_fleet_adapter" exec="door_supervisor" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_fleet_adapter" exec="lift_supervisor" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_task_ros2" exec="rmf_task_dispatcher" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="bidding_time_window" value="2.0"/>
  </node>

  <include file="$(find-pkg-share rmf_visualization)/visualization.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="map_name" value="L1"/>
    <arg name="viz_config_file"
       value="$(find-pkg-share kioto)/rviz/configu.rviz"/>
  </include>

  <include file="$(find-pkg-share kioto)/launch/simulation.launch.xml">
    <arg name="map_name" value="kioto"/>
  </include>

  <include file="$(find-pkg-share project_fleet_adapter)/launch/fleet_adapter.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="config_file" value="$(find-pkg-share kioto)/config/tinyRobot_config.yaml"/>
    <arg name="nav_graph_file" value="$(find-pkg-share kioto)/maps/kioto/nav_graphs/0.yaml"/>
  </include>

</launch>
