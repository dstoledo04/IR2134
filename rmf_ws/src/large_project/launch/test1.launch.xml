<?xml version="1.0"?>
<launch>

  <arg name="use_sim_time" default="true" />
  <arg name="failover_mode" default="false" />
  <arg name="use_tpe" default="false" />

  <!-- Core (RMF) -->
  <include file="$(find-pkg-share large_project)/config/launch/test1.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)" />
  </include>

  <!-- Simulation (Gazebo) -->
  <include file="$(find-pkg-share large_project)/launch/simulation.launch.xml">
    <arg name="map_name" value="test1_ign/test1" />
  </include>

</launch>
