<?xml version='1.0'?>
<launch>
  <arg name="map_package" default="large_project"/>
  <arg name="map_name"/>
  <arg name="gazebo_version" default="8"/>
  <arg name="headless" default="false"/>
  <arg name="sim_update_rate" default="100"/>

  <let name="world_path"
     value="$(find-pkg-share $(var map_package))/maps/$(var map_name).world" />

  <group>
    <set_env name="GZ_SIM_RESOURCE_PATH"
         value="$(find-pkg-share large_project)/buildings/models:$(find-pkg-share large_project)/maps:$(env GZ_SIM_RESOURCE_PATH)" />

    <set_env name="IGN_GAZEBO_RESOURCE_PATH"
            value="$(find-pkg-share large_project)/buildings/models:$(find-pkg-share large_project)/maps:$(env IGN_GAZEBO_RESOURCE_PATH)" />

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
      <arg name="gz_args" value="-r -v 3 $(var world_path) -z $(var sim_update_rate)"/>
    </include>
  </group>

  <node pkg="ros_gz_bridge"
        exec="parameter_bridge"
        args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock" />
</launch>
