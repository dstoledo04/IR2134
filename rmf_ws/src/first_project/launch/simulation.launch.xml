<?xml version='1.0'?>
<launch>
  <arg name="map_package" default="first_project"/>
  <arg name="map_name" description="Name of the project map to simulate"/>
  <arg name="headless" default="false"/>

  <!-- Rutas como en el PDF -->
  <let name="world_path"
       value="$(find-pkg-share $(var map_package))/maps/$(var map_name)_ign/$(var map_name).world"/>

  <let name="model_path"
       value="$(find-pkg-share $(var map_package))/maps/$(var map_name)_ign/models"/>

  <!-- Gazebo Sim (gz sim) -->
  <let name="gz_headless" if="$(var headless)" value=" -s "/>
  <let name="gz_headless" unless="$(var headless)" value=""/>

  <executable cmd="gz sim -r -v 4$(var gz_headless) $(var world_path)" output="both">
    <env name="GZ_SIM_RESOURCE_PATH" value="$(var model_path)"/>
  </executable>
  <node pkg="ros_gz_bridge"
      exec="parameter_bridge"
      args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock"
      output="screen"/>
</launch>
